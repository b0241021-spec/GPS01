<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 標題 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GPS 模擬器"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:layout_marginBottom="16dp" />

            <!-- 當前位置顯示（不可修改） -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="當前 GPS 位置"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/currentLocationDisplay"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="text"
                android:hint="緯度, 經度"
                android:textColor="@color/foreground"
                android:textColorHint="@color/muted"
                android:background="@drawable/status_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- 目標位置輸入（可修改） -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="覆蓋 GPS 位置"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/targetLocationInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="text"
                android:hint="輸入緯度, 經度"
                android:textColor="@color/foreground"
                android:textColorHint="@color/muted"
                android:background="@color/surface"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- 方向滑塊 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:text="方向"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground" />

                    <TextView
                        android:id="@+id/directionText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:text="0°"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:gravity="end" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/directionSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- 速度滑塊 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:text="速度"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground" />

                    <TextView
                        android:id="@+id/speedText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:text="0.0 km/hr"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:gravity="end" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/speedSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- 開關控制 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:text="模擬"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/foreground" />

                <Switch
                    android:id="@+id/simulationSwitch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:text="移動"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/foreground" />

                <Switch
                    android:id="@+id/movingSwitch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 測試按鈕 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:spacing="8dp"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/startTestButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="0.5"
                    android:text="開始測試"
                    android:textColor="@color/background"
                    android:background="@color/primary" />

                <Button
                    android:id="@+id/stopTestButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="0.5"
                    android:text="停止測試"
                    android:textColor="@color/background"
                    android:background="@color/error" />
            </LinearLayout>

            <!-- 狀態顯示 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="狀態"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="就緒"
                android:textSize="12sp"
                android:textColor="@color/muted"
                android:background="@drawable/status_background"
                android:padding="12dp"
                android:minHeight="60dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
